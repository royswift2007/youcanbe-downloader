# ===================================================
# 1. Python 核心产物 (缓存、字节码)
# ===================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ===================================================
# 2. 虚拟环境 (体积巨大，严禁提交)
# ===================================================
venv/
.venv/
env/
ENV/
bin/
lib/
include/
share/

# ===================================================
# 3. 编译与打包产物 (PyInstaller/Distutils)
# ===================================================
build/
dist/
*.spec
*.egg-info/
.eggs/
*.whl
*.tar.gz
# 既然是打包，忽略掉这些编译后的执行文件
*.exe
*.bin

# ===================================================
# 4. 安装包工具 (Inno Setup)
# ===================================================
installer/
Output/
*.islog
*.iss.bak

# ===================================================
# 5. 媒体文件与下载数据 (针对 youcanbe-downloader)
# ===================================================
*.mp4
*.mp3
*.mkv
*.ts
*.m3u8
*.aria2
# 下载目录示例（如果你的下载文件夹叫 downloads，请取消下面这行的注释）
# downloads/

# ===================================================
# 6. 隐私、安全与敏感数据
# ===================================================
.env
*cookies.txt
*.sqlite
*.sqlite3
history.json
# 包含账号密码或 API Key 的本地文件建议也写在这
# config_private.json

# ===================================================
# 7. IDE 配置与系统临时文件
# ===================================================
.vscode/
.idea/
*.lnk
.DS_Store
Thumbs.db
*.log
startup_debug.log

# ===================================================
# 8. 项目特定临时文件
# ===================================================
window_pos.json
node_modules/
plans/other/
temp/
ai交接.txt